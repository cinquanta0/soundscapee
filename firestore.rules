rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }
    function isNotAnonymous() {
      return isAuth() && request.auth.token.firebase.sign_in_provider != 'anonymous';
    }
    function isAdmin() {
      return isAuth() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isAdmin', false) == true;
    }
    function isSchoolTeacher() {
      return isAuth() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('schoolRole', 'student') in ['teacher', 'admin'];
    }
    function isSchoolStudent() {
      return isAuth() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('schoolRole', 'student') in ['student', 'teacher', 'admin'];
    }
    function isSchoolVerified() {
      return isAuth()
        && (
          request.auth.token.email_verified == true
          || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('emailVerified', false) == true
        )
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('schoolDomainAllowed', false) == true;
    }
    function validString(val, maxLen) {
      return val is string && val.size() > 0 && val.size() <= maxLen;
    }
    function hasApprovedClassMembership(classId) {
      return classId is string
        && exists(/databases/$(database)/documents/classes/$(classId)/members/$(request.auth.uid))
        && get(/databases/$(database)/documents/classes/$(classId)/members/$(request.auth.uid)).data.get('status', 'pending') == 'approved';
    }

    // ── Rate limiting: controlla soundsQuota/{uid} prima di creare un suono ──
    function withinDailyLimit() {
      let quotaPath = /databases/$(database)/documents/soundsQuota/$(request.auth.uid);
      return !exists(quotaPath) || get(quotaPath).data.get('count', 0) < 10;
    }

    // ── USERS ─────────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isAuth();

      allow create: if isOwner(userId)
                    && validString(request.resource.data.get('displayName', 'x'), 100);

      // Proprietario: può modificare tutto tranne isAdmin, schoolRole, emailVerified, schoolDomainAllowed
      // I campi scuola sono gestiti solo da Cloud Functions (Admin SDK)
      allow update: if isOwner(userId)
                    && validString(request.resource.data.get('displayName', 'x'), 100)
                    && !request.resource.data.diff(resource.data).affectedKeys()
                         .hasAny(['isAdmin', 'schoolRole', 'emailVerified', 'schoolDomainAllowed']);

      // Chiunque autenticato può incrementare battleWins (±1) — assegnato da finalizeBattle
      allow update: if isAuth()
                    && request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['battleWins'])
                    && request.resource.data.get('battleWins', 0) == resource.data.get('battleWins', 0) + 1;

      // Chiunque autenticato può modificare followersCount, followingCount, friendsCount (±1)
      // usato da follow/unfollow, accept/remove friend
      allow update: if isAuth() && !isOwner(userId)
                    && request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['followersCount', 'followingCount', 'friendsCount'])
                    && request.resource.data.get('followersCount', 0) >= resource.data.get('followersCount', 0) - 1
                    && request.resource.data.get('followersCount', 0) <= resource.data.get('followersCount', 0) + 1
                    && request.resource.data.get('followingCount', 0) >= resource.data.get('followingCount', 0) - 1
                    && request.resource.data.get('followingCount', 0) <= resource.data.get('followingCount', 0) + 1
                    && request.resource.data.get('friendsCount', 0) >= resource.data.get('friendsCount', 0) - 1
                    && request.resource.data.get('friendsCount', 0) <= resource.data.get('friendsCount', 0) + 1;

      allow delete: if isOwner(userId);

      match /followers/{followerId} {
        allow read: if isAuth();
        allow write: if isOwner(followerId);
      }
      match /following/{followingId} {
        allow read: if isAuth();
        allow write: if isOwner(request.auth.uid);
      }
    }

    // ── SOUNDS ────────────────────────────────────────────────────────────────
    match /sounds/{soundId} {
      allow read: if isAuth();

      allow create: if isNotAnonymous()
                    && isOwner(request.resource.data.userId)
                    && validString(request.resource.data.title, 200)
                    && request.resource.data.title.size() > 0
                    && withinDailyLimit();

      // Proprietario: può modificare i propri campi, ma NON i contatori sociali
      allow update: if isOwner(resource.data.userId)
                    && !request.resource.data.diff(resource.data).affectedKeys()
                         .hasAny(['userId', 'likesCount', 'commentsCount', 'listensCount']);

      // Qualsiasi utente autenticato può incrementare/decrementare likesCount (±1) — web
      allow update: if isAuth()
                    && request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['likesCount'])
                    && (request.resource.data.likesCount == resource.data.get('likesCount', 0) + 1
                        || request.resource.data.likesCount == resource.data.get('likesCount', 0) - 1);

      // Qualsiasi utente autenticato può incrementare/decrementare likes (±1) — mobile
      allow update: if isAuth()
                    && request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['likes'])
                    && (request.resource.data.likes == resource.data.get('likes', 0) + 1
                        || request.resource.data.likes == resource.data.get('likes', 0) - 1);

      // Utenti non-anonimi possono incrementare commentsCount (+1) — web
      allow update: if isNotAnonymous()
                    && request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['commentsCount'])
                    && request.resource.data.commentsCount == resource.data.get('commentsCount', 0) + 1;

      // Utenti non-anonimi possono incrementare/decrementare comments (±1) — mobile
      allow update: if isNotAnonymous()
                    && request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['comments'])
                    && (request.resource.data.comments == resource.data.get('comments', 0) + 1
                        || request.resource.data.comments == resource.data.get('comments', 0) - 1);

      // Qualsiasi utente autenticato può incrementare listensCount (+1) — web
      allow update: if isAuth()
                    && request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['listensCount'])
                    && request.resource.data.listensCount == resource.data.get('listensCount', 0) + 1;

      // Qualsiasi utente autenticato può incrementare listens (+1) — mobile
      allow update: if isAuth()
                    && request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['listens'])
                    && request.resource.data.listens == resource.data.get('listens', 0) + 1;

      allow delete: if isOwner(resource.data.userId);

      match /likes/{userId} {
        allow read: if isAuth();
        allow write: if isOwner(userId);
      }
      match /comments/{commentId} {
        allow read: if isAuth();
        allow create: if isNotAnonymous()
                      && isOwner(request.resource.data.userId)
                      && validString(request.resource.data.text, 1000);
        allow delete: if isOwner(resource.data.userId);
        allow update: if false;
      }
    }

    // ── SOUNDS QUOTA (rate limiting giornaliero) ───────────────────────────────
    // Il client legge/scrive il proprio documento quota.
    // La Cloud Function può scrivere con Admin SDK ignorando queste regole.
    match /soundsQuota/{userId} {
      allow read: if isOwner(userId);
      // Il client aggiorna solo count e date (non altri campi)
      allow write: if isOwner(userId)
                   && request.resource.data.keys().hasOnly(['count', 'date'])
                   && request.resource.data.count is int
                   && request.resource.data.count >= 0
                   && request.resource.data.count <= 10;
    }

    // ── REMIXES ───────────────────────────────────────────────────────────────
    match /remixes/{remixId} {
      allow read: if isAuth() &&
                    (resource.data.userId == request.auth.uid ||
                     resource.data.get('isPublic', false) == true);
      allow create: if isNotAnonymous() && isOwner(request.resource.data.userId);
      allow update: if isOwner(resource.data.userId)
                    && !request.resource.data.diff(resource.data).affectedKeys()
                         .hasAny(['userId']);
      allow delete: if isOwner(resource.data.userId);
    }

    // ── REPORTS ───────────────────────────────────────────────────────────────
    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isNotAnonymous()
                    && isOwner(request.resource.data.userId)
                    && validString(request.resource.data.reason, 200);
      allow update, delete: if false;
    }

    // ── COMMUNITIES ───────────────────────────────────────────────────────────
    match /communities/{communityId} {
      allow read: if isAuth();
      allow create: if isNotAnonymous();
      allow update: if isAdmin()
                    || isOwner(resource.data.creatorId)
                    || (isAuth()
                        && request.resource.data.diff(resource.data).affectedKeys()
                             .hasOnly(['membersCount']));
      allow delete: if isAdmin() || isOwner(resource.data.creatorId);

      match /members/{userId} {
        allow read: if isAuth();
        // Scrittura: il diretto interessato, il creatore della community, oppure admin/moderatore
        allow write: if isOwner(userId)
                     || (isAuth() && get(/databases/$(database)/documents/communities/$(communityId)).data.creatorId == request.auth.uid)
                     || (isAuth() && exists(/databases/$(database)/documents/communities/$(communityId)/members/$(request.auth.uid))
                         && get(/databases/$(database)/documents/communities/$(communityId)/members/$(request.auth.uid)).data.role in ['admin', 'moderator']);
      }

      match /joinRequests/{userId} {
        allow read: if isAuth() && (
          isOwner(userId)
          || get(/databases/$(database)/documents/communities/$(communityId)).data.creatorId == request.auth.uid
          || (exists(/databases/$(database)/documents/communities/$(communityId)/members/$(request.auth.uid))
              && get(/databases/$(database)/documents/communities/$(communityId)/members/$(request.auth.uid)).data.role in ['admin', 'moderator'])
        );
        allow create: if isOwner(userId) && isNotAnonymous();
        allow delete: if isOwner(userId)
                      || (isAuth() && get(/databases/$(database)/documents/communities/$(communityId)).data.creatorId == request.auth.uid)
                      || (isAuth() && exists(/databases/$(database)/documents/communities/$(communityId)/members/$(request.auth.uid))
                          && get(/databases/$(database)/documents/communities/$(communityId)/members/$(request.auth.uid)).data.role in ['admin', 'moderator']);
      }

      match /chat/{messageId} {
        allow read: if isAuth()
                    && exists(/databases/$(database)/documents/communities/$(communityId)/members/$(request.auth.uid));
        allow create: if isNotAnonymous()
                      && isOwner(request.resource.data.senderId)
                      && exists(/databases/$(database)/documents/communities/$(communityId)/members/$(request.auth.uid));
        allow update: if isAuth()
                      && exists(/databases/$(database)/documents/communities/$(communityId)/members/$(request.auth.uid))
                      && (
                        // Reazioni: solo il campo reactions
                        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions'])
                        // Pin: solo admin/moderatore
                        || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isPinned'])
                            && get(/databases/$(database)/documents/communities/$(communityId)/members/$(request.auth.uid)).data.role in ['admin', 'moderator'])
                      );
        allow delete: if isOwner(resource.data.senderId)
                      || (isAuth() && exists(/databases/$(database)/documents/communities/$(communityId)/members/$(request.auth.uid))
                          && get(/databases/$(database)/documents/communities/$(communityId)/members/$(request.auth.uid)).data.role in ['admin', 'moderator']);
      }

      match /posts/{postId} {
        allow read: if isAuth();
        allow create: if isNotAnonymous()
                      && isOwner(request.resource.data.userId)
                      && validString(request.resource.data.get('text', 'x'), 2000);
        allow delete: if isOwner(resource.data.userId) || isAdmin();
        allow update: if false;
      }
    }

    // ── SOUND BATTLES ────────────────────────────────────────────────────────
    match /battles/{battleId} {
      allow read: if isAuth();
      allow create: if isNotAnonymous();
      // Partecipanti: gestiscono lo stato della battaglia
      allow update: if isAuth()
                    && (request.auth.uid == resource.data.challengerId
                        || request.auth.uid == resource.data.opponentId);
      // Spettatori non-partecipanti: possono solo incrementare challengerVotes o opponentVotes (+1)
      allow update: if isAuth()
                    && request.auth.uid != resource.data.challengerId
                    && request.auth.uid != resource.data.opponentId
                    && request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['challengerVotes', 'opponentVotes'])
                    && (
                      (request.resource.data.get('challengerVotes', 0) == resource.data.get('challengerVotes', 0) + 1
                       && request.resource.data.get('opponentVotes', 0) == resource.data.get('opponentVotes', 0))
                      || (request.resource.data.get('opponentVotes', 0) == resource.data.get('opponentVotes', 0) + 1
                          && request.resource.data.get('challengerVotes', 0) == resource.data.get('challengerVotes', 0))
                    );
      allow delete: if isAuth() && request.auth.uid == resource.data.challengerId;

      match /votes/{userId} {
        allow read: if isAuth();
        // setDoc usa uid come doc ID → un solo voto per utente, non partecipanti
        allow create, update: if isAuth() && request.auth.uid == userId
                      && request.auth.uid != get(/databases/$(database)/documents/battles/$(battleId)).data.challengerId
                      && request.auth.uid != get(/databases/$(database)/documents/battles/$(battleId)).data.opponentId;
      }
    }

    // ── COLLAB SESSIONS ───────────────────────────────────────────────────────
    match /collabSessions/{sessionId} {
      allow read: if isAuth()
                  && (request.auth.uid == resource.data.hostId
                      || request.auth.uid == resource.data.guestId);
      allow create: if isNotAnonymous();
      allow update: if isAuth()
                    && (request.auth.uid == resource.data.hostId
                        || request.auth.uid == resource.data.guestId);
      allow delete: if isAuth()
                    && request.auth.uid == resource.data.hostId;
    }

    // ── CHALLENGES ────────────────────────────────────────────────────────────
    match /challenges/{challengeId} {
      allow read: if isAuth();
      allow create, update: if isAdmin();
      allow delete: if isAdmin() || request.auth.uid == resource.data.createdBy;

      match /participants/{userId} {
        allow read: if isAuth();
        allow write: if isOwner(userId);
      }
    }

    // ── NOTIFICATIONS ─────────────────────────────────────────────────────────
    // Le notifiche vengono create solo da Cloud Functions (Admin SDK, bypassa le regole).
    // Il client può solo leggerle e aggiornarle (solo campo 'read') o eliminarle.
    match /notifications/{notificationId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if false; // solo Cloud Function
      allow update: if isOwner(resource.data.userId)
                    && request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['read']);
      allow delete: if isOwner(resource.data.userId);
    }

    // ── PODCAST ───────────────────────────────────────────────────────────────
    match /podcast/{episodeId} {
      // Keep feed queries stable across legacy/new podcast schemas.
      // Class-specific visibility is still enforced in the dedicated class feeds.
      allow read: if isAuth();
      allow create: if isNotAnonymous()
                    && isOwner(request.resource.data.userId)
                    && validString(request.resource.data.title, 200);
      allow update: if (isOwner(resource.data.userId)
                        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['userId']))
                    || (isAuth()
                        && request.resource.data.diff(resource.data).affectedKeys()
                           .hasOnly(['likesCount', 'dislikesCount', 'commentsCount']));
      allow delete: if isOwner(resource.data.userId);

      match /likes/{userId} {
        allow read: if isAuth();
        allow write: if isAuth() && request.auth.uid == userId;
      }
      match /dislikes/{userId} {
        allow read: if isAuth();
        allow write: if isAuth() && request.auth.uid == userId;
      }
      match /comments/{commentId} {
        allow read: if isAuth();
        allow create: if isNotAnonymous() && isOwner(request.resource.data.userId);
        allow delete: if isOwner(resource.data.userId);
      }
    }

    // ── RADIO ─────────────────────────────────────────────────────────────────
    match /radio/{roomId} {
      allow read: if isAuth();
      allow create: if isNotAnonymous()
                    && isOwner(request.resource.data.hostId)
                    && validString(request.resource.data.title, 200);
      allow update: if isAuth()
                    && (
                      // Ascoltatori: solo contatore
                      request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly(['listenerCount'])
                      ||
                      // Host: gestione tracce, speaker, cohost, fine trasmissione, programma
                      (isOwner(resource.data.hostId)
                       && request.resource.data.diff(resource.data).affectedKeys()
                            .hasOnly(['currentTrackIndex', 'trackStartedAt', 'isLive',
                                      'currentChunkUrl', 'chunkIndex', 'listenerCount', 'hostMicLive',
                                      'activeSpeakers', 'cohosts', 'scheduledFor', 'startedAt', 'playlist']))
                    );
      allow delete: if isOwner(resource.data.hostId);

      // Chat live
      match /chat/{msgId} {
        allow read: if isAuth();
        allow create: if isNotAnonymous()
                      && validString(request.resource.data.text, 500);
        allow delete: if false;
      }

      // Reazioni emoji
      match /reactions/{reactionId} {
        allow read: if isAuth();
        allow create: if isNotAnonymous();
        allow delete: if false;
      }

      // Mani alzate
      match /handRaises/{userId} {
        allow read: if isAuth();
        // Il listener crea/aggiorna la propria mano; l'host può aggiornare (per segnare picked)
        allow create: if isNotAnonymous() && isOwner(userId);
        allow update: if isNotAnonymous()
                      && (isOwner(userId)
                          || isOwner(get(/databases/$(database)/documents/radio/$(roomId)).data.hostId));
        allow delete: if isAuth()
                      && (isOwner(userId)
                          || isOwner(get(/databases/$(database)/documents/radio/$(roomId)).data.hostId));
      }

      // Suggerimenti playlist collaborativa
      match /suggestions/{suggestionId} {
        allow read: if isAuth();
        allow create: if isNotAnonymous()
                      && isOwner(request.resource.data.userId);
        allow update: if isOwner(get(/databases/$(database)/documents/radio/$(roomId)).data.hostId)
                      && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']);
        allow delete: if isOwner(get(/databases/$(database)/documents/radio/$(roomId)).data.hostId);
      }
    }

    // ── STATI (stories 24h) ───────────────────────────────────────────────────
    match /stati/{statoId} {
      allow read: if isAuth();
      allow create: if isNotAnonymous()
                    && isOwner(request.resource.data.userId)
                    && validString(request.resource.data.get('title', 'x'), 200);
      allow update: if isAuth()
                    && request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['visti']);
      allow delete: if isOwner(resource.data.userId);

      match /reactions/{userId} {
        allow read: if isAuth();
        allow create, update: if isAuth()
                              && request.auth.uid == userId
                              && request.resource.data.userId == request.auth.uid
                              && validString(request.resource.data.emoji, 8);
        allow delete: if isAuth() && request.auth.uid == userId;
      }

      match /replies/{replyId} {
        allow read: if isAuth();
        allow create: if isNotAnonymous()
                      && request.resource.data.userId == request.auth.uid
                      && validString(request.resource.data.text, 500);
        allow update, delete: if false;
      }
    }

    // ── FRIEND REQUESTS ───────────────────────────────────────────────────────
    // requestId = [uid1, uid2].sort().join('_')
    match /friendRequests/{requestId} {
      // resource == null quando il doc non esiste (getDoc su doc assente) → permettiamo la lettura
      allow read: if isAuth() && (resource == null || request.auth.uid in resource.data.users);
      allow create: if isAuth()
                    && request.resource.data.initiatedBy == request.auth.uid
                    && request.auth.uid in request.resource.data.users
                    && request.resource.data.users.size() == 2
                    && request.resource.data.status == 'pending';
      // Solo il ricevente può accettare (non chi ha inviato)
      allow update: if isAuth()
                    && request.auth.uid in resource.data.users
                    && request.auth.uid != resource.data.initiatedBy
                    && request.resource.data.status == 'accepted'
                    && request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['status', 'respondedAt']);
      // Entrambi possono cancellare (rifiuta, annulla, rimuovi amico)
      allow delete: if isAuth() && request.auth.uid in resource.data.users;
    }

    // ── FOLLOWS (relazioni follow/unfollow) ──────────────────────────────────
    match /follows/{followId} {
      allow read: if isAuth();
      allow create: if isAuth() && isOwner(request.resource.data.followerId);
      allow delete: if isAuth() && isOwner(resource.data.followerId);
    }

    // ── PLAYLISTS ─────────────────────────────────────────────────────────────
    match /playlists/{playlistId} {
      // Chiunque autenticato può leggere (playlist pubbliche per condivisione)
      allow read: if isAuth();

      // Creazione: solo utente autenticato, deve essere proprietario
      allow create: if isNotAnonymous()
                    && isOwner(request.resource.data.userId)
                    && validString(request.resource.data.name, 200)
                    && request.resource.data.podcastIds is list;

      // Aggiornamento: solo proprietario, non può cambiare userId/createdAt
      allow update: if isOwner(resource.data.userId)
                    && !request.resource.data.diff(resource.data).affectedKeys()
                         .hasAny(['userId', 'createdAt']);

      // Eliminazione: solo proprietario
      allow delete: if isOwner(resource.data.userId);
    }

    // ── CLASSES (ITS scuola) ──────────────────────────────────────────────────
    match /classes/{classId} {
      allow read: if isAuth();
      allow create: if isNotAnonymous()
                    && isOwner(request.resource.data.teacherId)
                    && isSchoolTeacher()
                    && isSchoolVerified()
                    && validString(request.resource.data.name, 120)
                    && validString(request.resource.data.code, 12);
      allow update: if isOwner(resource.data.teacherId)
                    && !request.resource.data.diff(resource.data).affectedKeys()
                         .hasAny(['teacherId', 'code', 'createdAt']);
      allow delete: if isOwner(resource.data.teacherId);

      match /members/{userId} {
        allow read: if isAuth();
        allow create, update: if isAuth()
                              && (
                                // teacher gestisce membri della sua classe
                                (isOwner(get(/databases/$(database)/documents/classes/$(classId)).data.teacherId)
                                  && isSchoolTeacher()
                                  && request.resource.data.role in ['student', 'teacher']
                                  && request.resource.data.status in ['pending', 'approved', 'rejected'])
                                // utente entra da solo come student o teacher
                                || (isOwner(userId)
                                    && request.resource.data.userId == request.auth.uid
                                    && request.resource.data.role in ['student']
                                    && request.resource.data.status == 'pending'
                                    && isSchoolStudent())
                              );
        allow delete: if isAuth()
                      && (isOwner(userId)
                          || isOwner(get(/databases/$(database)/documents/classes/$(classId)).data.teacherId));
      }
    }

    // ── LESSONS (pubblicate da teacher) ───────────────────────────────────────
    match /lessons/{lessonId} {
      allow read: if isAuth();
      allow create: if isNotAnonymous()
                    && isOwner(request.resource.data.teacherId)
                    && isSchoolTeacher()
                    && isSchoolVerified()
                    && validString(request.resource.data.title, 200)
                    && validString(request.resource.data.classId, 80);
      allow update: if isOwner(resource.data.teacherId)
                    && isSchoolTeacher()
                    && !request.resource.data.diff(resource.data).affectedKeys()
                         .hasAny(['teacherId', 'classId', 'createdAt']);
      allow delete: if isOwner(resource.data.teacherId);
    }

    // ── LESSON SUBMISSIONS (student -> teacher approval) ──────────────────────
    match /lessonSubmissions/{submissionId} {
      allow read: if isAuth()
                  && (
                    isOwner(resource.data.studentId)
                    || isOwner(resource.data.teacherId)
                    || hasApprovedClassMembership(resource.data.classId)
                  );
      // Lo studente crea la propria consegna in pending
      allow create: if isNotAnonymous()
                    && isOwner(request.resource.data.studentId)
                    && isSchoolStudent()
                    && request.resource.data.status == 'pending'
                    && validString(request.resource.data.classId, 80)
                    && validString(request.resource.data.lessonId, 80)
                    && validString(request.resource.data.podcastId, 80)
                    && validString(request.resource.data.teacherId, 80);
      // Solo la teacher della submission può approvare/rifiutare
      allow update: if isNotAnonymous()
                    && isOwner(resource.data.teacherId)
                    && isSchoolTeacher()
                    && request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['status', 'teacherFeedback', 'reviewedAt', 'grade', 'gradeComment'])
                    && request.resource.data.status in ['approved', 'rejected'];
      allow delete: if false;
    }

    match /auditLogs/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ── APP CONFIG (versione minima, maintenance mode) ─────────────────────────
    match /appConfig/{docId} {
      allow read: if isAuth();   // chiunque loggato può leggere (maintenance, minBuild)
      allow write: if isAdmin(); // solo admin può scrivere
    }

    // ── REMIX QUOTA (usato dalla Cloud Function per rate limiting) ────────────
    match /remixQuota/{userId} {
      allow read: if isOwner(userId);
      allow write: if false; // solo Cloud Function con Admin SDK
    }

    // ── MESSAGGI VOCALI ───────────────────────────────────────────────────────
    // conversationId deterministico: [uid1, uid2].sort().join('_')
    match /conversations/{convId} {
      // get: verifica partecipante (resource == null quando la conv non esiste ancora)
      allow get: if isAuth() && (resource == null || request.auth.uid in resource.data.participants);
      // list: la query filtra già per participants array-contains uid, isAuth() basta
      allow list: if isAuth();
      allow create: if isAuth() && request.auth.uid in request.resource.data.participants;
      allow update: if isAuth() && request.auth.uid in resource.data.participants;
      allow delete: if false;
    }

    match /messaggi/{msgId} {
      // get: verifica mittente o destinatario
      allow get: if isAuth() &&
                   (resource.data.senderId == request.auth.uid ||
                    resource.data.receiverId == request.auth.uid);
      // list: la query filtra già per conversationId, isAuth() basta
      allow list: if isAuth();
      // Solo il mittente autenticato può creare
      allow create: if isAuth() && request.resource.data.senderId == request.auth.uid;
      // Solo il destinatario può aggiornare (segna come ascoltato)
      allow update: if isAuth() &&
                    resource.data.receiverId == request.auth.uid &&
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['ascoltato']);
      // Solo il mittente può eliminare il proprio messaggio
      allow delete: if isAuth() && resource.data.senderId == request.auth.uid;
    }
  }
}
