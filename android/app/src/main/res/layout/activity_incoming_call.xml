<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0A0A0A"
    android:gravity="center_horizontal">

    <!-- App label -->
    <TextView
        android:id="@+id/tvAppLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="56dp"
        android:text="MIUSLYK"
        android:textColor="#00FF9C"
        android:textSize="11sp"
        android:letterSpacing="0.15"
        android:fontFamily="monospace"
        android:alpha="0.7" />

    <!-- Spacer top -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Avatar + pulse rings -->
    <FrameLayout
        android:layout_width="200dp"
        android:layout_height="200dp">

        <View
            android:id="@+id/pulseRing2"
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:layout_gravity="center"
            android:background="@drawable/sc_call_ring" />

        <View
            android:id="@+id/pulseRing1"
            android:layout_width="158dp"
            android:layout_height="158dp"
            android:layout_gravity="center"
            android:background="@drawable/sc_call_ring" />

        <TextView
            android:id="@+id/tvAvatar"
            android:layout_width="110dp"
            android:layout_height="110dp"
            android:layout_gravity="center"
            android:gravity="center"
            android:textSize="44sp"
            android:textColor="#F7F8FF"
            android:textStyle="bold"
            android:background="@drawable/sc_call_avatar_bg" />

    </FrameLayout>

    <View android:layout_width="match_parent" android:layout_height="28dp" />

    <!-- Caller name -->
    <TextView
        android:id="@+id/tvCallerName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#F7F8FF"
        android:textSize="28sp"
        android:textStyle="bold"
        android:gravity="center"
        android:paddingLeft="32dp"
        android:paddingRight="32dp" />

    <View android:layout_width="match_parent" android:layout_height="8dp" />

    <!-- Status -->
    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Chiamata vocale in arrivo"
        android:textColor="#7A8099"
        android:textSize="14sp"
        android:fontFamily="monospace" />

    <!-- Spacer bottom -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Action buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="64dp">

        <!-- Decline -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <FrameLayout
                android:id="@+id/btnDecline"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:background="@drawable/sc_call_decline_bg"
                android:clickable="true"
                android:focusable="true"
                android:elevation="6dp"
                android:outlineProvider="background">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="&#x2715;"
                    android:textSize="26sp"
                    android:textColor="#F7F8FF" />
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Rifiuta"
                android:textColor="#7A8099"
                android:textSize="12sp"
                android:fontFamily="monospace" />
        </LinearLayout>

        <View android:layout_width="80dp" android:layout_height="1dp" />

        <!-- Accept -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <FrameLayout
                android:id="@+id/btnAccept"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:background="@drawable/sc_call_accept_bg"
                android:clickable="true"
                android:focusable="true"
                android:elevation="6dp"
                android:outlineProvider="background">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="&#x1F4DE;"
                    android:textSize="26sp" />
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Rispondi"
                android:textColor="#00FF9C"
                android:textSize="12sp"
                android:fontFamily="monospace" />
        </LinearLayout>

    </LinearLayout>

</LinearLayout>
