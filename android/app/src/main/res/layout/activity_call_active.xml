<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0A0A0A"
    android:gravity="center_horizontal">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="56dp"
        android:text="MIUSLYK"
        android:textColor="#00FF9C"
        android:textSize="11sp"
        android:letterSpacing="0.15"
        android:fontFamily="monospace"
        android:alpha="0.7" />

    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <TextView
        android:id="@+id/tvActiveCallerName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#F7F8FF"
        android:textSize="32sp"
        android:textStyle="bold"
        android:gravity="center"
        android:paddingLeft="32dp"
        android:paddingRight="32dp" />

    <View android:layout_width="match_parent" android:layout_height="12dp" />

    <TextView
        android:id="@+id/tvCallDuration"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="00:00"
        android:textColor="#00FF9C"
        android:textSize="22sp"
        android:fontFamily="monospace" />

    <View android:layout_width="match_parent" android:layout_height="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Chiamata in corso"
        android:textColor="#7A8099"
        android:textSize="13sp"
        android:fontFamily="monospace" />

    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginBottom="72dp">

        <FrameLayout
            android:id="@+id/btnHangUp"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:background="@drawable/sc_call_decline_bg"
            android:clickable="true"
            android:focusable="true"
            android:elevation="6dp"
            android:outlineProvider="background">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="&#x1F4F5;"
                android:textSize="26sp" />
        </FrameLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Riattacca"
            android:textColor="#FF5C79"
            android:textSize="12sp"
            android:fontFamily="monospace" />

    </LinearLayout>

</LinearLayout>
